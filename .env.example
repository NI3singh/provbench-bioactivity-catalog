# ─────────────────────────────────────────────────────────────────────────
# ProvBench — environment variables. Copy to `.env` and fill in your values.
# ─────────────────────────────────────────────────────────────────────────

# Postgres connection string (Neon / Supabase / any Postgres).
# Neon: create a project at https://neon.tech and copy the connection string
# (it already includes ?sslmode=require). The pooled endpoint works for both the
# local loader and the deployed API.
#   postgresql://<user>:<password>@<endpoint>-pooler.<region>.aws.neon.tech/<db>?sslmode=require
DATABASE_URL=postgresql://user:password@your-endpoint-pooler.region.aws.neon.tech/dbname?sslmode=require

# HuggingFace token (write access) — only needed for s9 publish.
# Create one at https://huggingface.co/settings/tokens (role: write).
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini API key — only needed by the backend's /api/extract endpoint.
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Frontend → backend base URL (used by the React app at build time).
VITE_API_URL=http://localhost:8000

# Optional: override the HuggingFace dataset namespace/name (defaults to the HF username).
# HF_REPO_ID=Ni3SinghR/provbench-egfr-bioactivity
