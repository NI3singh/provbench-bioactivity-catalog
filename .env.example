# ─────────────────────────────────────────────────────────────────────────
# ProvBench — environment variables. Copy to `.env` and fill in your values.
# ─────────────────────────────────────────────────────────────────────────

# Supabase Postgres connection string.
# IMPORTANT: use the CONNECTION POOLER host from the Supabase dashboard
# (Project Settings → Database → Connection string → "Connection pooling"),
# NOT the direct db.<ref>.supabase.co host (that one is IPv6-only and Render
# cannot reach it).  The pooler host looks like:
#   postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# Port 5432 = Session pooler (used by the local loader s8, supports COPY).
# Port 6543 = Transaction pooler (fine for the read-only backend).
SUPABASE_DB_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# HuggingFace token (write access) — only needed for s9 publish.
# Create one at https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini API key — only needed by the backend's /api/extract endpoint.
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Frontend → backend base URL (used by the React app at build time).
# Local dev default:
VITE_API_URL=http://localhost:8000
